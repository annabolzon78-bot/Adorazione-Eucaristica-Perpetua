# ── Database ──────────────────────────────────────────────────
DATABASE_URL="postgresql://avuser:avpassword@localhost:5432/adorazione_viva"

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-random-32-char-minimum-secret-key"
JWT_REFRESH_SECRET="change-this-to-another-random-32-char-minimum-key"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── App ───────────────────────────────────────────────────────
NODE_ENV="development"
PORT=4000
CORS_ORIGIN="http://localhost:5173"
LOG_LEVEL="info"
BCRYPT_ROUNDS=12

# ── Frontend ──────────────────────────────────────────────────
VITE_API_URL="http://localhost:4000/api"
